{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(diabetes_predictions_total{status=\"success\"}[5m])",
          "refId": "A",
          "legendFormat": "Successful Predictions/sec"
        }
      ],
      "title": "Prediction Rate (Success)",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "diabetes_predictions_total{status=\"success\"}",
          "refId": "A",
          "legendFormat": "Total Successful"
        },
        {
          "expr": "diabetes_predictions_total{status=\"error\"}",
          "refId": "B",
          "legendFormat": "Total Errors"
        }
      ],
      "title": "Total Predictions",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(diabetes_prediction_latency_seconds_bucket[5m]))",
          "refId": "A",
          "legendFormat": "p95 Latency"
        },
        {
          "expr": "histogram_quantile(0.99, rate(diabetes_prediction_latency_seconds_bucket[5m]))",
          "refId": "B",
          "legendFormat": "p99 Latency"
        }
      ],
      "title": "Prediction Latency Percentiles",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "diabetes_active_requests",
          "refId": "A",
          "legendFormat": "Active Requests"
        }
      ],
      "title": "Active Requests",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "mlflow_connection_status",
          "refId": "A",
          "legendFormat": "MLflow Status"
        }
      ],
      "title": "MLflow Connection Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "options": {
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "OK",
                  "color": "green"
                },
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ]
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 27,
  "style": "dark",
  "tags": ["diabetes", "ml-service", "predictions"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
